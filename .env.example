# Choose AI provider: local | gemini | openai
# AI_PROVIDER controls image diagnosis. Chat can use AI_CHAT_PROVIDER below.
AI_PROVIDER="local"

# Optional chat priority: openai | groq | gemini
# Chat automatically falls back to the other configured providers if the first one fails.
AI_CHAT_PROVIDER="openai"

# Gemini server-side config
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_CHAT_FALLBACK_MODELS="gemini-2.0-flash,gemini-2.0-flash-lite"

# OpenAI server-side config
OPENAI_API_KEY="MY_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4.1-mini"

# Groq server-side config
GROQ_API_KEY="MY_GROQ_API_KEY"
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_CHAT_FALLBACK_MODELS="llama-3.1-8b-instant,gemma2-9b-it"
GROQ_DIAGNOSIS_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# OpenRouter fallback config
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_DIAGNOSIS_MODEL="openai/gpt-4o-mini"

# Local AI model config
AI_MODEL_PATH="./AI/model.onnx"
AI_CLASS_NAMES_PATH="./AI/tomato_onnx_class_names.json"
AI_INFERENCE_SCRIPT="./AI/predict_disease_onnx.py"
AI_IMAGE_SIZE="32"

# Optional mango model. These defaults point to the bundled PyTorch project:
# AI_MANGO_MODEL_PATH="./AI/Mango-Leaf-Disease-Prediction-main/multi_model_bundle.pth"
# AI_MANGO_INFERENCE_SCRIPT="./AI/Mango-Leaf-Disease-Prediction-main/predict_mango_bundle.py"
# AI_MANGO_IMAGE_SIZE="224"
AI_LOW_CONFIDENCE_THRESHOLD="0.40"
AI_LOW_MARGIN_THRESHOLD="0.12"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase client-side config.
# Existing/old API names are still supported in code:
# VITE_SUPABASE_URL
# VITE_SUPABASE_ANON_KEY
# NEXT_PUBLIC_SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Server-side only. Do not expose this to frontend code.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# VNPay server-side config. Use sandbox credentials from VNPay merchant portal.
VNPAY_TMN_CODE="your-vnpay-terminal-code"
VNPAY_HASH_SECRET="your-vnpay-hash-secret"
VNPAY_PAYMENT_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
# Optional. Leave empty to let the server build /api/payments/vnpay/return from the current host.
VNPAY_RETURN_URL=""
# Compatibility names used by VNPay's Node demo.
vnp_TmnCode="your-vnpay-terminal-code"
vnp_HashSecret="your-vnpay-hash-secret"
vnp_Url="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
# Send this public URL to VNPay after deployment: https://your-domain.com/api/payments/vnpay/ipn

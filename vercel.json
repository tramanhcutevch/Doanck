{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "excludeFiles": "{AI/Mango-Leaf-Disease-Prediction-main/**,AI/cassava/**,**/__pycache__/**,**/*.pyc,**/*.ipynb,**/*.h5,**/*.pth}"
    }
  }
}
